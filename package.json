{
  "name": "nosgestesclimat-aides",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT License",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "npx prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/src/main.js",
    "start:dev": "dotenv -e .env.run nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",

    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",

    "test:unit": "dotenv -e .env.test -- jest --runInBand --bail",
    "test:int": "dotenv -e .env.test -- jest  --config ./test/jest-int.json --runInBand --bail --forceExit",
    "test": "npm run test:unit && npm run test:int",

    "db:generate": "dotenv -e .env.test -- npx prisma generate",
    "db:migrate": "dotenv -e .env.test -- npx prisma migrate dev && dotenv -e .env.run -- npx prisma migrate dev ",
    "db:migrate_scalingo": "npx prisma migrate deploy",

    "prepare": "husky",

    "execute_local": "dotenv -e .env.run -- node dist/src/console.js",
    "execute": "node dist/src/console.js"

  },
  "dependencies": {
    "@getbrevo/brevo": "^1.0.1",
    "@etalab/decoupage-administratif": "^6.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.5.0",
    "axios": "^1.13.6",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "pg": "^8.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.7",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "test",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "testTimeout": 20000
  }

}
